[Unit]
Description=Reachy Claw Robot Stack
After=docker.service
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/home/recomputer/reachy-deploy
EnvironmentFile=-/home/recomputer/reachy-deploy/.env
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down
TimeoutStartSec=180

[Install]
WantedBy=multi-user.target
