FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential meson pkg-config \
    libcairo2-dev libgirepository1.0-dev gobject-introspection \
    libportaudio2 portaudio19-dev ffmpeg libasound2-dev \
    libgl1 libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY . .
RUN pip install --no-cache-dir silero-vad onnxruntime
RUN pip install --no-cache-dir -e ".[audio,mediapipe-vision]"

CMD ["reachy-claw", "-v"]
